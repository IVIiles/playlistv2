```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Python specific
*.pyo
*.pyd
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.tox/
.coverage.*

# JavaScript/Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.jest/
.nyc_output/

# Java specific
target/
.gradle/
*.jar
*.war
*.ear

# C/C++ specific
*.a
*.lib
*.obj
*.o
*.so
*.dylib
*.dll
*.exe

# Go specific
*.exe
*.test
*.prof
vendor/

# Ruby specific
*.gem
*.rbc
.bundle/
vendor/bundle/
vendor/cache/
vendor/gems/
vendor/ruby/

# Rust specific
target/
Cargo.lock

# Julia specific
julia-*/

# Zig specific
zig*/
```